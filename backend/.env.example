# =============================================================
# KSI Backend 환경변수 예시 — 실제 키 값을 채워 .env 파일로 복사
# 절대 이 파일에 실제 값을 입력하지 말 것 (.gitignore 적용됨)
# =============================================================

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# AI API 키
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...

# KRX Data API
KRX_API_KEY=

# CORS — 프론트엔드 운영 도메인 (Vercel 배포 URL)
FRONTEND_URL=https://ksi.vercel.app

# 서버 환경 설정
APP_ENV=production

# Railway 자동 주입 — 로컬 개발 시 직접 지정
PORT=8000
